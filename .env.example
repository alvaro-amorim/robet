# ============================================================
# ROBET — .env.example
# MVP local: Copa do Mundo, pré-jogo, simulação e combinadas
# ============================================================

# ============================================================
# 1) PREENCHER MANUALMENTE NO SEU .env REAL
# Copie este arquivo para .env e preencha apenas esta seção primeiro.
# O .env real nunca deve ser enviado ao GitHub.
# ============================================================

# Chave da API-Football / API-Sports.
# Necessária somente quando USE_MOCK_PROVIDERS=false.
FOOTBALL_API_KEY=

# Chave da The Odds API.
# Necessária somente quando USE_MOCK_PROVIDERS=false.
ODDS_API_KEY=

# Chave da OpenAI.
# Opcional. No MVP, a IA não decide recomendações.
# Use somente para resumo/relatório de aprendizado quando AI_ENABLED=true.
OPENAI_API_KEY=

# Modelo da OpenAI para resumo/aprendizado.
# Preencher somente se AI_ENABLED=true.
# Exemplo: use um model id disponível na sua conta da OpenAI.
OPENAI_MODEL_SUMMARY=

# Segredo local da aplicação.
# Pode trocar por uma frase longa aleatória antes de produção.
SECRET_KEY=change_me_local_secret


# ============================================================
# 2) CONFIGURAÇÕES JÁ PREENCHIDAS PARA O MVP LOCAL
# Em geral, não precisa mexer agora.
# ============================================================

APP_NAME=Robet
APP_ENV=development
APP_DEBUG=true
APP_TIMEZONE=America/Sao_Paulo
APP_LOCALE=pt-BR
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# Primeiro ciclo deve rodar com mocks, sem depender de API real.
USE_MOCK_PROVIDERS=true

# Banco local via Docker/PostgreSQL.
POSTGRES_USER=robet
POSTGRES_PASSWORD=robet_password
POSTGRES_DB=robet
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://robet:robet_password@localhost:5432/robet

# Redis fica previsto, mas desligado no MVP.
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0

# Provedor de futebol.
FOOTBALL_DATA_PROVIDER=api_football
FOOTBALL_API_BASE_URL=https://v3.football.api-sports.io
FOOTBALL_API_TIMEOUT_SECONDS=20
FOOTBALL_API_CACHE_TTL_SECONDS=3600

# Competição inicial e futura.
PRIMARY_COMPETITION=world_cup
SECONDARY_COMPETITION=brazil_serie_a
DEFAULT_SEASON=2026
AUTO_DISCOVER_COMPETITIONS=true
WORLD_CUP_SEARCH_TERMS=world cup,fifa world cup,copa do mundo
BRAZIL_SERIE_A_SEARCH_TERMS=brasileirao,brazil serie a,serie a brazil

# Provedor de odds.
ODDS_PROVIDER=the_odds_api
ODDS_API_BASE_URL=https://api.the-odds-api.com/v4
ODDS_API_REGIONS=eu
ODDS_API_ODDS_FORMAT=decimal
ODDS_API_DATE_FORMAT=iso
ODDS_PRIMARY_SPORT_KEY=soccer_fifa_world_cup
ODDS_AUTO_DISCOVER_SPORT_KEYS=true
ODDS_PRIMARY_SPORT_SEARCH_TERMS=world cup,fifa,soccer
ODDS_SECONDARY_SPORT_KEY=soccer_brazil_campeonato
ODDS_API_MARKETS=h2h,totals
ODDS_API_TIMEOUT_SECONDS=20
ODDS_API_CACHE_TTL_SECONDS=900

# Mercados e entrada manual.
ENABLE_MANUAL_ODDS=true
ENABLE_COMBINED_BET_EVALUATOR=true
ENABLE_BET_REARRANGEMENT=true
ENABLED_SIMPLE_MARKETS=h2h,totals,btts,team_to_win,corners,cards,manual

# Segurança de produto.
ENABLE_LIVE_MODE=false
ENABLE_REAL_MONEY_MODE=false
ENABLE_AUTO_BETTING=false
ENABLE_BOOKMAKER_SCRAPING=false
ENABLE_ANTIBOT_BYPASS=false
ENABLE_LOGGED_BOOKMAKER_AUTOMATION=false

# Simulação.
BANKROLL_INITIAL_BALANCE=1000.00
BANKROLL_CURRENCY=BRL
MAX_STAKE_PER_RECOMMENDATION_PERCENT=1.0
ENABLE_DAILY_LOSS_BLOCK=false
ENABLE_DAILY_LOSS_WARNING=true
ALLOW_MARTINGALE=false
ALLOW_LOSS_RECOVERY_MODE=false

# Regras de recomendação.
RECOMMENDATION_MODE=ranked_all
MIN_EDGE=0.04
MIN_EXPECTED_VALUE=0.02
MIN_CONFIDENCE=0.60
MIN_ODD=1.10
MAX_ODD=50.00
REQUIRE_POSITIVE_EV=true

# Apostas combinadas.
COMBINED_BET_MIN_LEGS=2
COMBINED_BET_MAX_LEGS=6
COMBINED_BET_CORRELATION_MODE=conservative_penalty
COMBINED_BET_DEFAULT_CORRELATION_PENALTY=0.15
COMBINED_BET_AUTO_SIMULATE=false

# Aprendizado.
LEARNING_ENABLED=true
LEARNING_AUTO_UPDATE_WEIGHTS=false
LEARNING_REQUIRE_HUMAN_REVIEW_FOR_STRATEGY_CHANGE=true
LEARNING_STORE_SUCCESSFUL_RECOMMENDATIONS=true
LEARNING_STORE_FAILED_RECOMMENDATIONS=true

# IA opcional e barata.
AI_ENABLED=false
AI_PROVIDER=openai
AI_USE_FOR_DECISION=false
AI_USE_FOR_RECOMMENDATION=false
AI_USE_FOR_LEARNING_SUMMARY=true
AI_USE_FOR_CONTEXT_COMPACTION=true
AI_CACHE_ENABLED=true
AI_DAILY_COST_LIMIT_USD=0.25
AI_MONTHLY_COST_LIMIT_USD=5.00

# Controle de custo.
ENABLE_COST_TRACKING=true
TOTAL_DAILY_COST_LIMIT_USD=1.00
TOTAL_MONTHLY_COST_LIMIT_USD=10.00
BLOCK_EXTERNAL_CALLS_WHEN_LIMIT_REACHED=true

# Logs.
LOG_LEVEL=INFO
LOG_JSON=true
LOG_API_PAYLOADS=false
LOG_AI_PROMPTS=false
LOG_AI_RESPONSES=false
LOG_RECOMMENDATIONS=true
LOG_LEARNING_EVENTS=true

# Desenvolvimento.
SEED_DATABASE=true
TESTING=false
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
